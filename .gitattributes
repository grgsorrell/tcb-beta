# Normalize line endings to LF in the repo AND on checkout, to kill the
# Windows CRLF churn that was rewriting worker.js/app.html cosmetically on
# every commit. Text files are stored and checked out as LF.

* text=auto eol=lf

# Explicit text types (belt-and-suspenders for detection edge cases)
*.js    text eol=lf
*.mjs   text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.jsonc text eol=lf
*.toml  text eol=lf
*.css   text eol=lf
*.txt   text eol=lf
*.sql   text eol=lf
*.py    text eol=lf

# Binary assets — never normalize or diff
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.gif   binary
